# MySQL Database
MYSQL_ROOT_PASSWORD=your_strong_root_password
MYSQL_DATABASE=bms
MYSQL_USER=bms_user
MYSQL_PASSWORD=your_strong_db_password

# JWT Secrets (generate new ones for production!)
# Run: openssl rand -hex 32
JWT_SECRET=replace_with_random_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_random_64_char_hex

# Encryption Key for SMTP password storage
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# Your domain (used for CORS and email links)
FRONTEND_URL=https://yourdomain.com
